flowchart LR
    P[Producer] --> Q[(Queue)]
    Q --> C[Consumer]
    C -->|✓ 成功| OK[ack / 削除]
    C -->|✗ 失敗| R{retry<br/>max_retries}
    R -->|成功| OK
    R -->|全て失敗| DLQ[(DLQ<br/>退避)]

    classDef q fill:#FF2D20,stroke:#BC002D,color:#fff
    classDef ok fill:#2a9d8f,stroke:#1b6b60,color:#fff
    classDef fail fill:#8B0000,stroke:#4a0000,color:#fff
    classDef actor fill:#1A202C,stroke:#1A202C,color:#fff
    class Q q
    class OK ok
    class DLQ fail
    class P,C actor
