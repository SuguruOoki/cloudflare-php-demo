{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-php-container-demo",
  "main": "src/worker.ts",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },

  "containers": [
    {
      "class_name": "AppContainer",
      "image": "./Dockerfile",
      "max_instances": 10,
      "instance_type": "basic"
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "class_name": "AppContainer",
        "name": "APP"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AppContainer"]
    }
  ]

  // 必要に応じて有効化（未作成ならコメントのまま）
  // "d1_databases": [
  //   { "binding": "DB", "database_name": "prod-db", "database_id": "REPLACE_ME" }
  // ],
  // "r2_buckets": [
  //   { "binding": "FILES", "bucket_name": "uploads" }
  // ],
  // "kv_namespaces": [
  //   { "binding": "CACHE", "id": "REPLACE_ME" }
  // ]
}
