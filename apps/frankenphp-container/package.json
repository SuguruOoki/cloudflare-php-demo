{
  "name": "cloudflare-php-container-demo",
  "version": "0.1.0",
  "private": true,
  "description": "PHP running on Cloudflare Containers via FrankenPHP",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail",
    "docker:build": "docker build -t cloudflare-php-container-demo:local .",
    "docker:run": "docker run -p 8080:8080 cloudflare-php-container-demo:local"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.90.0"
  }
}
