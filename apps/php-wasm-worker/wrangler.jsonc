{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-php-wasm-demo",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "REPLACE_WITH_KV_ID"
    }
  ]
}
